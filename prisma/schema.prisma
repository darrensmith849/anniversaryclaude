generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ──────────────────────────────────────────

enum RequestStatus {
  NEW
  REVIEWING
  PROPOSAL_PENDING
  AWAITING_CLIENT
  CONFIRMED
  CLOSED
  CANCELLED
}

enum BudgetBand {
  UNDER_50K
  BAND_50_100K
  BAND_100_200K
  BAND_200_500K
  OVER_500K
}

enum StayStatus {
  DRAFT
  PROPOSED
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PartnerCategory {
  LODGE
  HOTEL
  VILLA
  RESTAURANT
  ACTIVITY
  TRANSPORT
  FLORIST
  PHOTOGRAPHER
  OTHER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// ─── Models ─────────────────────────────────────────

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Client {
  id               String               @id @default(cuid())
  name             String
  email            String               @unique
  phone            String?
  timezone         String               @default("Africa/Johannesburg")
  city             String?
  anniversaryDate  DateTime?
  dietaryAllergies String?
  accessibility    String?
  notes            String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  requests         AnniversaryRequest[]
  stays            Stay[]
}

model AnniversaryRequest {
  id            String        @id @default(cuid())
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id])
  status        RequestStatus @default(NEW)

  // ─── Brief: Occasion ────────────────────
  anniversaryYear  String?
  celebrationWindow String?
  datesFlexible    Boolean       @default(false)
  startDate        DateTime?
  endDate          DateTime?
  travelRegions    String[]

  // ─── Brief: Experience ──────────────────
  experienceStyles String[]
  luxuryTone       String?
  pace             String?
  specialMoments   String?

  // ─── Brief: Trip Details ────────────────
  tripLength       String?
  travellerCount   String?
  departureCity    String?
  budgetBand       BudgetBand?

  // ─── Brief: Personal ───────────────────
  preferences      String?
  surprises        String?
  messageToTeam    String?

  // ─── Legacy / flexible ─────────────────
  vibeTags      String[]
  notes         String?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  stays         Stay[]
  tasks         Task[]
  activityLogs  ActivityLog[]

  // Phase 2: email thread linking
  // emailThreadId String?
}

model Stay {
  id           String     @id @default(cuid())
  requestId    String
  request      AnniversaryRequest @relation(fields: [requestId], references: [id])
  clientId     String
  client       Client     @relation(fields: [clientId], references: [id])
  propertyName String
  location     String?
  checkIn      DateTime?
  checkOut     DateTime?
  status       StayStatus @default(DRAFT)
  confirmationRef String?
  costEstimate    String?
  notes        String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  tasks        Task[]
}

model Partner {
  id               String          @id @default(cuid())
  name             String
  category         PartnerCategory
  contactName      String?
  contactEmail     String?
  contactPhone     String?
  location         String?
  tags             String[]
  notes            String?
  isOfficialPartner Boolean        @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}

model Task {
  id          String       @id @default(cuid())
  requestId   String?
  request     AnniversaryRequest? @relation(fields: [requestId], references: [id])
  stayId      String?
  stay        Stay?        @relation(fields: [stayId], references: [id])
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueAt       DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model ActivityLog {
  id          String              @id @default(cuid())
  requestId   String?
  request     AnniversaryRequest? @relation(fields: [requestId], references: [id])
  action      String
  description String?
  actor       String?
  metadata    Json?
  createdAt   DateTime            @default(now())
}
