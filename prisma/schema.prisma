generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  hashedPassword String
  name           String?
  role           String   @default("ADMIN")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Client {
  id               String               @id @default(cuid())
  name             String
  email            String               @unique
  phone            String?
  timezone         String               @default("Africa/Johannesburg")
  city             String?
  anniversaryDate  DateTime?
  preferences      String?
  dietaryAllergies String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  requests         AnniversaryRequest[]
  stays            Stay[]
  emailJobs        EmailJob[]
}

enum RequestStatus {
  NEW
  QUALIFIED
  SHORTLIST_SENT
  OUTREACH_IN_PROGRESS
  OPTIONS_RECEIVED
  DECIDED
  BOOKED
  COMPLETE
}

model AnniversaryRequest {
  id            String        @id @default(cuid())
  clientId      String
  client        Client        @relation(fields: [clientId], references: [id])
  status        RequestStatus @default(NEW)
  datesFlexible Boolean       @default(false)
  startDate     DateTime?
  endDate       DateTime?
  budgetBand    String?
  vibeTags      String[]
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  stays         Stay[]
  tasks         Task[]
  emailJobs     EmailJob[]
}

enum StayStatus {
  DRAFT
  PROPOSED
  CONFIRMED
  CANCELLED
  COMPLETED
}

model Stay {
  id                      String             @id @default(cuid())
  requestId               String
  request                 AnniversaryRequest @relation(fields: [requestId], references: [id])
  clientId                String
  client                  Client             @relation(fields: [clientId], references: [id])
  propertyName            String
  location                String?
  checkIn                 DateTime?
  checkOut                DateTime?
  nights                  Int?
  status                  StayStatus         @default(DRAFT)
  costAmount              Decimal?           @db.Decimal(12, 2)
  costCurrency            String             @default("ZAR")
  confirmationNumber      String?
  cancellationPolicy      String?
  bookingMethod           String?
  travellersCount         Int?
  roomType                String?
  clientPreferences       String?
  hostAgency              String?
  guestEmail              String?
  memberId                String?
  perksAdded              Boolean            @default(false)
  requestsCheckedAndAdded Boolean            @default(false)
  addedToRewardsTracker   Boolean            @default(false)
  isVvip                  Boolean            @default(false)
  vipFollowUpStatus       String?
  checkInStatus           String?
  notesForAdmin           String?
  customFields            Json?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  tasks                   Task[]
  emailJobs               EmailJob[]
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  details   String?
  userId    String?
  createdAt DateTime @default(now())
}

enum PartnerCategory {
  ACCOMMODATION
  RESTAURANT
  ACTIVITY
  TRANSPORT
  FLORIST
  PHOTOGRAPHER
  SPA
  OTHER
}

model Partner {
  id                String          @id @default(cuid())
  name              String
  category          PartnerCategory
  location          String?
  tags              String[]
  isOfficialPartner Boolean         @default(false)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model Task {
  id        String              @id @default(cuid())
  title     String
  status    TaskStatus          @default(TODO)
  priority  TaskPriority        @default(MEDIUM)
  dueAt     DateTime?
  requestId String?
  request   AnniversaryRequest? @relation(fields: [requestId], references: [id])
  stayId    String?
  stay      Stay?               @relation(fields: [stayId], references: [id])
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
}

enum EmailTemplateType {
  PARTNER_OUTREACH
  VIP_PERKS_REQUEST
  FOLLOW_UP
  CUSTOM
}

model EmailTemplate {
  id              String            @id @default(cuid())
  name            String
  type            EmailTemplateType
  subjectTemplate String
  bodyTemplate    String
  variablesSchema Json?
  active          Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  emailJobs       EmailJob[]
}

enum EmailJobStatus {
  DRAFT
  NEEDS_REVIEW
  APPROVED
  SENT
  FAILED
}

model EmailJob {
  id           String              @id @default(cuid())
  templateId   String?
  template     EmailTemplate?      @relation(fields: [templateId], references: [id])
  status       EmailJobStatus      @default(DRAFT)
  toAddresses  String[]
  ccAddresses  String[]
  bccAddresses String[]
  subject      String
  bodyHtml     String
  bodyText     String?
  requestId    String?
  request      AnniversaryRequest? @relation(fields: [requestId], references: [id])
  stayId       String?
  stay         Stay?               @relation(fields: [stayId], references: [id])
  clientId     String?
  client       Client?             @relation(fields: [clientId], references: [id])
  approvedBy   String?
  approvedAt   DateTime?
  sentAt       DateTime?
  resendId     String?
  errorMessage String?
  metadata     Json?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}
